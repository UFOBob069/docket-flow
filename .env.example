# Client — Firebase web app (create in Firebase Console)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server — paste full JSON of a Firebase service account (for API route token verification)
# Generate: Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Calendar — service account with Domain-Wide Delegation
# Uses the same service account as Firebase Admin. DWD must be enabled in:
#   Workspace Admin → Security → API controls → Domain-wide delegation
#   Authorized scopes: https://www.googleapis.com/auth/calendar.events
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=primary
# The @ramosjames.com user to impersonate — calendar events appear from this address
GOOGLE_IMPERSONATE_EMAIL=
# The @ramosjames.com user to send email reminders from (via Gmail API DWD)
GOOGLE_REMINDER_EMAIL=
# Secret to protect the cron endpoint (set in Vercel project settings)
CRON_SECRET=
