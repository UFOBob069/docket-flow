# Supabase — create project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Authentication → Providers: Google (OAuth) only.
# Dashboard → Authentication → URL Configuration:
#   - Site URL = your live app (https://…), NOT localhost, or OAuth returns to localhost.
#   - Redirect URLs: include https://YOUR_HOST/auth/callback and http://localhost:3000/auth/callback
# Vercel: set canonical origin so OAuth redirect_to matches the allow list (omit on local dev).
NEXT_PUBLIC_SITE_URL=

# Server only — Settings → API → service_role (for /api/cron/send-reminders; bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Calendar — service account with Domain-Wide Delegation
# Workspace Admin → Security → API controls → Domain-wide delegation
# Authorized scopes: https://www.googleapis.com/auth/calendar.events
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=primary
# The @ramosjames.com user to impersonate — calendar events appear from this address
GOOGLE_IMPERSONATE_EMAIL=
# Firm SOL milestone calendar (Domain-Wide Delegation must impersonate this user)
GOOGLE_SOL_MILESTONE_IMPERSONATE_EMAIL=legalassistant@ramosjames.com
# Group / secondary calendar id where six SOL checkpoints are created (not "primary")
GOOGLE_SOL_MILESTONE_CALENDAR_ID=c_fdf8d70155c50c02fecf733cc8a2aeed08abc04e835166f638bac7db4d37eb1c@group.calendar.google.com
# The @ramosjames.com user to send email reminders from (via Gmail API DWD)
GOOGLE_REMINDER_EMAIL=
# Secret to protect the cron endpoint (set in Vercel project settings)
CRON_SECRET=your-long-random-string-here
