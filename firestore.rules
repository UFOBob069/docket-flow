rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isRamosJames() {
      return request.auth != null
        && request.auth.token.email.matches('.*@ramosjames[.]com$');
    }

    match /cases/{caseId} {
      allow read, create, update, delete: if isRamosJames();

      match /events/{eventId} {
        allow read, create, update, delete: if isRamosJames();
      }
    }

    match /contacts/{contactId} {
      allow read, create, update, delete: if isRamosJames();
    }
  }
}
